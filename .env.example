# .env.example
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=tdgames-preview
R2_PUBLIC_URL=https://prv.tdgamestudio.com

# Comma-separated IPs allowed to view "Internal only" share links.
# Behind Cloudflare the real client IP is in CF-Connecting-IP header.
# Leave empty to block everyone when share_internal_only is enabled.
# Example: SHARE_INTERNAL_ALLOWED_IPS=203.0.113.1,203.0.113.2
SHARE_INTERNAL_ALLOWED_IPS=
